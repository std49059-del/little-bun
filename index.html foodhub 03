            { id: 9, nameTh: "อ่อนแอ้น", nameEn: "On-An" },
            { id: 10, nameTh: "สถานีของทอด", nameEn: "Fried Station" },
            { id: 11, nameTh: "ชาบูเสียบไม้ล้าน 9", nameEn: "Shabu Skewer Lan 9" },
            { id: 12, nameTh: "ส้มตำคุณนาย", nameEn: "Madame Somtum" },
            { id: 13, nameTh: "ก๋วยเตี๋ยวน่องไก่ ราดหน้า ข้าวต้ม", nameEn: "Chicken Drumstick Noodles & Rad Na" },
            { id: 14, nameTh: "ข้าวราดแกง ไข่เจียวบุฟเฟ่ต์ สปาเก็ตตี้", nameEn: "Curry Rice & Omelet Buffet" }
        ];

        // Mock Menu Generator for each shop
        const baseMenus = [
            { id: 101, nameTh: "เมนูซิกเนเจอร์จานหลัก", nameEn: "Signature Main Dish", price: 45, available: true },
            { id: 102, nameTh: "เมนูพิเศษยอดนิยม", nameEn: "Popular Special Menu", price: 55, available: true },
            { id: 103, nameTh: "เมนูขายดีประจำวัน (หมด)", nameEn: "Daily Best Seller (Out of stock)", price: 40, available: false }
        ];

        // --- DOM INITIALIZATION ---
        document.addEventListener("DOMContentLoaded", () => {
            initLocationDropdown();
            renderShops();
            setupEventListeners();
            updateLanguageDOM();
        });

        // Initialize location options
        function initLocationDropdown() {
            const select = document.getElementById("locationSelect");
            select.innerHTML = `<option value="" disabled selected>-- เลือกสถานที่ / Select Location --</option>`;
            locations.forEach(loc => {
                const opt = document.createElement("option");
                opt.value = loc;
                opt.textContent = loc;
                select.appendChild(opt);
            });
        }

        // Setup Application Wide Event Listeners
        function setupEventListeners() {
            // Language Switcher
            document.getElementById("langToggle").addEventListener("click", () => {
                currentLang = currentLang === 'th' ? 'en' : 'th';
                document.getElementById("langToggle").textContent = currentLang === 'th' ? 'EN' : 'TH';
                updateLanguageDOM();
                renderShops();
                renderCart();
            });

            // Close Modal
            document.getElementById("closeModal").addEventListener("click", () => {
                document.getElementById("menuModal").style.display = "none";
            });

            // Checkout Event
            document.getElementById("checkoutBtn").addEventListener("click", runCheckoutSimulation);
        }

        // Translate Text Content of Dom dynamically
        function updateLanguageDOM() {
            document.querySelectorAll("[data-i18n]").forEach(elem => {
                const key = elem.getAttribute("data-i18n");
                if(i18n[currentLang][key]) {
                    elem.textContent = i18n[currentLang][key];
                }
            });

            document.querySelectorAll("[data-i18n-placeholder]").forEach(elem => {
                const key = elem.getAttribute("data-i18n-placeholder");
                if(i18n[currentLang][key]) {
                    elem.setAttribute("placeholder", i18n[currentLang][key]);
                }
            });
        }

        // --- RENDER SHOPS ---
        function renderShops() {
            const grid = document.getElementById("shopsGrid");
            grid.innerHTML = "";

            shopsData.forEach(shop => {
                const name = currentLang === 'th' ? shop.nameTh : shop.nameEn;
                const btnText = i18n[currentLang].btn_select_menu;
                
                const card = document.createElement("div");
                card.className = "shop-card";
                card.innerHTML = `
                    <img src="https://placehold.co/300x200/F2C94C/333333?text=${encodeURIComponent(name)}" alt="${name}" class="shop-img">
                    <div class="shop-info">
                        <div class="shop-title">${name}</div>
                        <button class="btn-primary" onclick="openMenuModal(${shop.id})">${btnText}</button>
                    </div>
                `;
                grid.appendChild(card);
            });
        }

        // --- OPEN DYNAMIC MENU MODAL ---
        function openMenuModal(shopId) {
            const shop = shopsData.find(s => s.id === shopId);
            const shopName = currentLang === 'th' ? shop.nameTh : shop.nameEn;
            document.getElementById("modalShopName").textContent = shopName;

            const modalBody = document.getElementById("modalMenuBody");
            modalBody.innerHTML = "";

            baseMenus.forEach(item => {
                const itemName = currentLang === 'th' ? item.nameTh : item.nameEn;
                const statusClass = item.available ? 'status-available' : 'status-outofstock';
                const statusText = item.available ? i18n[currentLang].txt_available : i18n[currentLang].txt_outofstock;
                const disabledAttr = item.available ? '' : 'disabled';
                const cardClass = item.available ? 'menu-item-card' : 'menu-item-card out-of-stock';

                const menuCard = document.createElement("div");
                menuCard.className = cardClass;
                menuCard.innerHTML = `
                    <div class="menu-item-header">
                        <span>${itemName}</span>
                        <div>
                            <span style="margin-right:10px;">${item.price} ฿</span>
                            <span class="status-badge ${statusClass}">${statusText}</span>
                        </div>
                    </div>
                    
                    ${item.available ? `
                    <div class="customization">
                        <div class="custom-group">
                            <label>${i18n[currentLang].label_spicy}</label>
                            <div class="custom-options">
                                <label><input type="radio" name="spicy_${item.id}" value="None" checked> ${i18n[currentLang].opt_no_spicy}</label>
                                <label><input type="radio" name="spicy_${item.id}" value="Medium"> ${i18n[currentLang].opt_mid_spicy}</label>
                                <label><input type="radio" name="spicy_${item.id}" value="High"> ${i18n[currentLang].opt_high_spicy}</label>
                            </div>
                        </div>
                        <div class="custom-options" style="margin-top:10px;">
                            <label><input type="checkbox" id="egg_${item.id}"> ${i18n[currentLang].label_egg}</label>
                            <label><input type="checkbox" id="noveg_${item.id}"> ${i18n[currentLang].label_no_veg}</label>
                            <label><input type="checkbox" id="noodle_${item.id}"> ${i18n[currentLang].label_more_noodle}</label>
                        </div>
                    </div>
                    ` : ''}

                    <button class="btn-primary btn-add-cart" ${disabledAttr} onclick="addItemToCart(${shopId}, ${item.id})">
                        ${i18n[currentLang].btn_add_to_cart}
                    </button>
                `;
                modalBody.appendChild(menuCard);
            });

            document.getElementById("menuModal").style.display = "flex";
        }

        // --- CART OPERATIONS ---
        function addItemToCart(shopId, itemId) {
            const shop = shopsData.find(s => s.id === shopId);
            const baseItem = baseMenus.find(m => m.id === itemId);

            // Read Customizations
            const spicyVal = document.querySelector(`input[name="spicy_${itemId}"]:checked`).value;
            const addEgg = document.getElementById(`egg_${itemId}`).checked;
            const noVeg = document.getElementById(`noveg_${itemId}`).checked;
            const addNoodle = document.getElementById(`noodle_${itemId}`).checked;

            // Calculate exact item price with additions
            let finalPrice = baseItem.price;
            let customNotes = [];
            
            customNotes.push(`Spicy: ${spicyVal}`);
            if(addEgg) { finalPrice += 10; customNotes.push("+Egg"); }
            if(noVeg) { customNotes.push("No Veg"); }
            if(addNoodle) { finalPrice += 10; customNotes.push("+Noodle"); }

            // Cart Item structure unique creation
            const cartItem = {
                cartId: Date.now() + Math.random().toString(36).substr(2, 5),
                shopTh: shop.nameTh,
                shopEn: shop.nameEn,
                nameTh: `${baseItem.nameTh} (${customNotes.join(', ')})`,
                nameEn: `${baseItem.nameEn} (${customNotes.join(', ')})`,
                price: finalPrice,
                quantity: 1
            };

            cart.push(cartItem);
            renderCart();
            document.getElementById("menuModal").style.display = "none";
            
            // Auto Smooth Scroll to Cart Section
            document.getElementById("cart-section").scrollIntoView({ behavior: 'smooth' });
        }

        function renderCart() {
            const emptyMsg = document.getElementById("cartEmptyMessage");
            const content = document.getElementById("cartContent");
            const tbody = document.getElementById("cartItemsBody");

            if(cart.length === 0) {
                emptyMsg.style.display = "block";
                content.style.display = "none";
                return;
            }

            emptyMsg.style.display = "none";
            content.style.display = "block";
            tbody.innerHTML = "";

            let total = 0;
            cart.forEach(item => {
                const name = currentLang === 'th' ? item.nameTh : item.nameEn;
                const shopName = currentLang === 'th' ? item.shopTh : item.shopEn;
                total += item.price * item.quantity;

                const tr = document.createElement("tr");
                tr.innerHTML = `
                    <td><strong>${name}</strong></td>
                    <td>${shopName}</td>
                    <td>${item.price} ฿</td>
                    <td>${item.quantity}</td>
                    <td><button class="btn-delete" onclick="removeItemFromCart('${item.cartId}')">&times;</button></td>
                `;
                tbody.appendChild(tr);
            });

            document.getElementById("cartTotalAmount").textContent = total;
        }

        function removeItemFromCart(cartId) {
            cart = cart.filter(item => item.cartId !== cartId);
            renderCart();
        }

        // --- ORDER TRACKING SIMULATION ---
        function runCheckoutSimulation() {
            const locSelect = document.getElementById("locationSelect").value;
            if(!locSelect) {
                alert(i18n[currentLang].alert_location);
                document.getElementById("locationSelect").focus();
                return;
            }

            // Hide Cart layout, lock and load Tracking section smoothly
            const trackingSec = document.getElementById("tracking-section");
            trackingSec.style.display = "block";
            trackingSec.scrollIntoView({ behavior: 'smooth' });

            document.getElementById("trackingActive").style.display = "block";
            document.getElementById("trackingDone").style.display = "none";

            // State management array of stages
            const steps = ["step0", "step1", "step2", "step3"];
            const statuses = ["Preparing...", "Cooking...", "Delivering...", "Completed"];
            let currentStep = 0;

            // Reset step UI
            steps.forEach(s => document.getElementById(s).className = "step");
            document.getElementById("progressLineFill").style.width = "0%";

            // Simulation loop setup (Faster timeline execution for direct live demo value)
            document.getElementById("trackingStatusText").textContent = statuses[0];
            document.getElementById("step0").className = "step active";

            const interval = setInterval(() => {
                document.getElementById(steps[currentStep]).className = "step completed";
                currentStep++;

                if(currentStep < steps.length) {
                    document.getElementById(steps[currentStep]).className = "step active";
                    document.getElementById("trackingStatusText").textContent = statuses[currentStep];
                    
                    // Progress Calculation for line fill UI responsive scaling
                    let percent = (currentStep / (steps.length - 1)) * 100;
                    document.getElementById("progressLineFill").style.width = `${percent}%`;
                } else {
                    clearInterval(interval);
                    // Trigger Completed Delivery Interface UI state transition
                    document.getElementById("progressLineFill").style.width = "100%";
                    setTimeout(() => {
                        document.getElementById("trackingActive").style.display = "none";
                        document.getElementById("trackingDone").style.display = "block";
                        // Reset dynamic checkout status
                        cart = [];
                        renderCart();
                    }, 800);
                }
            }, 3000); // 3 seconds per simulated node pipeline transition
        }
    </script>
</body>
</html>
