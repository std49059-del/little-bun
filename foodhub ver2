            { id: 8, type: "noodle", th: "สุขเต็มชาม", en: "Happy Bowl" },
            { id: 9, type: "general", th: "อ่อนแอ้น", en: "On-An" },
            { id: 10, type: "general", th: "สถานีของทอด", en: "Fried Station" },
            { id: 11, type: "general", th: "ชาบูเสียบไม้ล้าน 9", en: "Shabu Skewer Million 9" },
            { id: 12, type: "rice", th: "ส้มตำคุณนาย", en: "Lady's Somtum" },
            { id: 13, type: "noodle", th: "ก๋วยเตี๋ยวน่องไก่ ราดหน้า ข้าวต้ม", en: "Chicken Drumstick Noodles & Rad Na" },
            { id: 14, type: "rice", th: "ข้าวราดแกง ไข่เจียวบุฟเฟ่ต์ สปาเก็ตตี้", en: "Curry Rice & Omelet Buffet" }
        ];

        // จำลองคลังข้อมูลรายการอาหารประจำแต่ละร้าน (สามารถเขียนทับแก้ไขได้จริงบนตัวแปรนี้เมื่อ Admin สั่งแก้ไข)
        let menuRegistry = {};
        shopsData.forEach(shop => {
            menuRegistry[shop.id] = [
                { id: `m-${shop.id}-1`, nameTh: "เมนูหลักแนะนำประจำร้าน", nameEn: "House Signature Dish", price: 40, status: "Available" },
                { id: `m-${shop.id}-2`, nameTh: "เมนูพิเศษยอดนิยม", nameEn: "Popular Choice Item", price: 50, status: "Available" },
                { id: `m-${shop.id}-3`, nameTh: "เมนูพรีเมียมเชฟกระทะเหล็ก", nameEn: "Chef Premium Selection", price: 60, status: "Out of Stock" }
            ];
        });

        // --- App Initialization ---
        window.addEventListener('DOMContentLoaded', () => {
            initLocationDropdown();
            renderShops();
            updateLanguageUI();
        });

        function initLocationDropdown() {
            const selectEl = document.getElementById('buildingSelect');
            selectEl.innerHTML = '';
            locationsData.forEach(loc => {
                const opt = document.createElement('option');
                opt.value = loc.id;
                opt.textContent = currentLang === 'th' ? loc.th : loc.en;
                selectEl.appendChild(opt);
            });
        }

        function renderShops() {
            const grid = document.getElementById('shopsGrid');
            grid.innerHTML = '';
            shopsData.forEach(shop => {
                const name = currentLang === 'th' ? shop.th : shop.en;
                const imgUrl = `https://placehold.co/400x250/F2C94C/333333?text=${encodeURIComponent(name)}`;
                
                const card = document.createElement('div');
                card.className = 'shop-card';
                card.innerHTML = `
                    <img src="${imgUrl}" alt="${name}" class="shop-img">
                    <div class="shop-info">
                        <div class="shop-name">${name}</div>
                        <button class="btn" onclick="openMenu(${shop.id})">${translations[currentLang].btn_select_menu}</button>
                    </div>
                `;
                grid.appendChild(card);
            });
        }

        // --- Authentication Actions (สำหรับคนควบคุมแก้ไขระบบร้านค้าเท่านั้น) ---
        function openLoginModal() { document.getElementById('loginModal').classList.add('active'); }
        function closeLoginModal() { document.getElementById('loginModal').classList.remove('active'); }

        function handleLogin(e) {
            e.preventDefault();
            const emailInput = document.getElementById('loginEmail').value;
            const passwordInput = document.getElementById('loginPassword').value;
            const errorMsg = document.getElementById('loginError');

            if (emailInput === 'std49059@sriyapai.ac.th' && passwordInput === '1869900778503') {
                isAdminLoggedIn = true;
                document.getElementById('adminBadgeBar').style.display = 'block';
                document.getElementById('logoutBtn').style.display = 'block';
                document.getElementById('loginNavBtn').style.display = 'none';
                errorMsg.style.display = 'none';
                closeLoginModal();
                if(document.getElementById('menuModal').classList.contains('active')) {
                    openMenu(activeShopId); // รีโหลดหน้าต่างเมนูให้กลายเป็นโหมดแก้ไขทันที
                }
            } else {
                errorMsg.style.display = 'block';
            }
        }

        function handleLogout() {
            isAdminLoggedIn = false;
            document.getElementById('adminBadgeBar').style.display = 'none';
            document.getElementById('logoutBtn').style.display = 'none';
            document.getElementById('loginNavBtn').style.display = 'block';
            document.getElementById('loginForm').reset();
            if(document.getElementById('menuModal').classList.contains('active')) {
                openMenu(activeShopId); // ปรับกลับเป็นโหมดผู้ซื้อปกติ
            }
        }

        // --- Menu List / Customization & Administration Control ---
        function openMenu(shopId) {
            activeShopId = shopId;
            const shop = shopsData.find(s => s.id === shopId);
            const shopName = currentLang === 'th' ? shop.th : shop.en;
            
            document.getElementById('modalShopName').textContent = shopName;
            const body = document.getElementById('modalMenuBody');
            body.innerHTML = '';

            const menus = menuRegistry[shopId];

            menus.forEach((item, index) => {
                const isAvailable = item.status === 'Available';
                const itemName = currentLang === 'th' ? item.nameTh : item.nameEn;
                const statusText = isAvailable ? translations[currentLang].available : translations[currentLang].out_of_stock;
                const badgeClass = isAvailable ? 'bg-green' : 'bg-red';

                const itemDiv = document.createElement('div');
                itemDiv.className = `menu-item ${isAvailable ? '' : 'out-of-stock'}`;

                // โครงสร้างตัวเลือกแต่งเพิ่มเติม Ontop แยกชนิดประเภทร้านค้า
                let ontopHTML = '';
                if(isAvailable) {
                    if (shop.type === 'noodle') {
                        ontopHTML = `
                            <div class="custom-grid">
                                <label><input type="checkbox" id="opt1-${item.id}"> ${translations[currentLang].opt_noodle}</label>
                                <label><input type="checkbox" id="opt2-${item.id}"> ${translations[currentLang].opt_topping}</label>
                                <label><input type="checkbox" id="opt3-${item.id}"> ${translations[currentLang].opt_wonton}</label>
                            </div>`;
                    } else if (shop.type === 'rice') {
                        ontopHTML = `
                            <div class="custom-grid">
                                <label><input type="checkbox" id="opt1-${item.id}"> ${translations[currentLang].opt_rice}</label>
                                <label><input type="checkbox" id="opt2-${item.id}"> ${translations[currentLang].opt_extra_side}</label>
                            </div>`;
                    }
                }

                // สิทธิ์คนคุมร้าน: แทรกฟอร์มแก้ไขข้อมูลเมนูอาหารหลังล็อกอินสำเร็จ
                let adminPanelHTML = '';
                if(isAdminLoggedIn) {
                    adminPanelHTML = `
                        <div class="admin-edit-panel">
                            <strong style="color: #2c3e50; font-size:0.85rem;">${translations[currentLang].admin_edit_panel || translations[currentLang].admin_edit_title}</strong>
                            <div style="display:grid; grid-template-columns: 2fr 1fr; gap:10px; margin-top:5px;">
                                <input type="text" id="editNameTh-${item.id}" value="${item.nameTh}" placeholder="ชื่อไทย">
                                <input type="number" id="editPrice-${item.id}" value="${item.price}" placeholder="ราคา">
                            </div>
                            <div style="margin-top:8px; display:flex; justify-content:space-between; align-items:center;">
                                <label style="font-size:0.85rem;">
                                    <input type="checkbox" id="editStatus-${item.id}" ${isAvailable ? 'checked' : ''}> พร้อมจำหน่าย (Available)
                                </label>
                                <button class="btn" style="width:auto; padding:4px 10px; font-size:0.8rem; background-color:#2980b9;" onclick="saveMenuEdit('${item.id}', ${index})">
                                    ${translations[currentLang].admin_save}
                                </button>
                            </div>
                        </div>
                    `;
                }

                itemDiv.innerHTML = `
                    <div>
                        <div class="menu-details">
                            <h4>${itemName} <span class="badge ${badgeClass}">${statusText}</span></h4>
                            <p class="menu-price">฿${item.price}</p>
                        </div>
                        
                        ${isAvailable && !isAdminLoggedIn ? `
                        <div class="custom-box">
                            <strong>${translations[currentLang].custom_spice}:</strong>
                            <div class="custom-grid">
                                <label><input type="radio" name="spice-${item.id}" value="None" checked> ${translations[currentLang].spice_none}</label>
                                <label><input type="radio" name="spice-${item.id}" value="Medium"> ${translations[currentLang].spice_mid}</label>
                                <label><input type="radio" name="spice-${item.id}" value="Hot"> ${translations[currentLang].spice_hot}</label>
                            </div>
                            ${ontopHTML ? `<strong style="display:block; margin-top:5px;">Ontop Option:</strong> ${ontopHTML}` : ''}
                            <button class="btn btn-yellow" style="margin-top:10px; padding:6px;" onclick="addToCart('${item.id}', ${shopId})">
                                ${translations[currentLang].btn_add_cart}
                            </button>
                        </div>
                        ` : ''}

                        ${adminPanelHTML}
                    </div>
                `;
                body.appendChild(itemDiv);
            });

            document.getElementById('menuModal').classList.add('active');
        }

        // ฟังก์ชันสั่งบันทึกการแก้ไขข้อมูลของร้านค้า (โดย Admin)
        function saveMenuEdit(menuId, index) {
            const newNameTh = document.getElementById(`editNameTh-${menuId}`).value;
            const newPrice = parseFloat(document.getElementById(`editPrice-${menuId}`).value) || 0;
            const isChecked = document.getElementById(`editStatus-${menuId}`).checked;
            
            // อัปเดตข้อมูลเซฟเข้าโครงสร้างคลังตรงๆ
            menuRegistry[activeShopId][index].nameTh = newNameTh;
            menuRegistry[activeShopId][index].price = newPrice;
            menuRegistry[activeShopId][index].status = isChecked ? 'Available' : 'Out of Stock';
            
            alert(currentLang === 'th' ? 'บันทึกความเปลี่ยนแปลงเรียบร้อย!' : 'Saved menu updates successfully!');
            openMenu(activeShopId); // สั่งวาดอัปเดตหน้าแสดงผลใหม่ในตัว
        }

        function closeModal() { document.getElementById('menuModal').classList.remove('active'); }

        // --- Cart Operations ---
        function addToCart(menuId, shopId) {
            const shop = shopsData.find(s => s.id === shopId);
            const itemTemplate = menuRegistry[shopId].find(m => m.id === menuId);
            
            const spiceEl = document.querySelector(`input[name="spice-${menuId}"]:checked`);
            const spiceVal = spiceEl ? spiceEl.value : 'None';

            let finalPrice = itemTemplate.price;
            let customNotes = [];
            if(spiceVal !== 'None') customNotes.push(`Spicy:${spiceVal}`);

            // ดึงค่าออปชั่น Ontop เสริมแต่ง
            const o1 = document.getElementById(`opt1-${menuId}`);
            const o2 = document.getElementById(`opt2-${menuId}`);
            const o3 = document.getElementById(`opt3-${menuId}`);

            if (shop.type === 'noodle') {
                if(o1 && o1.checked) { finalPrice += 10; customNotes.push('+เส้น'); }
                if(o2 && o2.checked) { finalPrice += 15; customNotes.push('+เครื่อง'); }
                if(o3 && o3.checked) { finalPrice += 10; customNotes.push('+เกี๊ยว'); }
            } else if (shop.type === 'rice') {
                if(o1 && o1.checked) { finalPrice += 10; customNotes.push('+ข้าว'); }
                if(o2 && o2.checked) { finalPrice += 20; customNotes.push('+กับข้าว'); }
            }

            const customKey = `${menuId}-${spiceVal}-${o1?.checked}-${o2?.checked}-${o3?.checked}`;
            const existingItem = cart.find(c => c.customKey === customKey);

            if(existingItem) {
                existingItem.quantity += 1;
            } else {
                cart.push({
                    customKey: customKey, shopTh: shop.th, shopEn: shop.en,
                    nameTh: itemTemplate.nameTh, nameEn: itemTemplate.nameEn,
                    price: finalPrice, quantity: 1, notes: customNotes.join(', ')
                });
            }

            renderCart();
            closeModal();
            document.getElementById('cartItemsContainer').scrollIntoView({ behavior: 'smooth' });
        }

        function removeFromCart(customKey) {
            cart = cart.filter(c => c.customKey !== customKey);
            renderCart();
        }

        function renderCart() {
            const container = document.getElementById('cartItemsContainer');
            const totalAmountEl = document.getElementById('cartTotalAmount');
            const checkoutBtn = document.getElementById('checkoutBtn');
            
            if(cart.length === 0) {
                container.innerHTML = `<p style="text-align: center; color: var(--gray-dark); padding: 20px 0;" data-i18n="cart_empty">${translations[currentLang].cart_empty}</p>`;
                totalAmountEl.textContent = '0';
                checkoutBtn.disabled = true;
                return;
            }

            container.innerHTML = '';
            let total = 0;
            cart.forEach(item => {
                const shopName = currentLang === 'th' ? item.shopTh : item.shopEn;
                const itemName = currentLang === 'th' ? item.nameTh : item.nameEn;
                const itemSubtotal = item.price * item.quantity;
                total += itemSubtotal;

                const cartDiv = document.createElement('div');
                cartDiv.className = 'cart-item';
                cartDiv.innerHTML = `
                    <div class="cart-item-info">
                        <strong>${itemName}</strong> x ${item.quantity}
                        <span class="cart-item-shop">🏢 ${shopName}</span>
                        ${item.notes ? `<span class="cart-item-customs">✨ (${item.notes})</span>` : ''}
                    </div>
                    <div class="cart-item-actions">
                        <div>฿${itemSubtotal}</div>
                        <button class="delete-btn" onclick="removeFromCart('${item.customKey}')">${currentLang === 'th' ? 'ลบออก' : 'Remove'}</button>
                    </div>
                `;
                container.appendChild(cartDiv);
            });
            totalAmountEl.textContent = total;
            checkoutBtn.disabled = false;
        }

        // --- Multi-Language Framework Switching ---
        function toggleLanguage() {
            currentLang = currentLang === 'th' ? 'en' : 'th';
            document.getElementById('langToggleBtn').textContent = currentLang === 'th' ? 'EN' : 'TH';
            
            const currentSelected = document.getElementById('buildingSelect').value;
            initLocationDropdown();
            document.getElementById('buildingSelect').value = currentSelected;
            
            renderShops();
            renderCart();
            updateLanguageUI();
            if(document.getElementById('menuModal').classList.contains('active')) {
                openMenu(activeShopId);
            }
        }

        function updateLanguageUI() {
            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                if(translations[currentLang][key]) el.textContent = translations[currentLang][key];
            });
            document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
                const key = el.getAttribute('data-i18n-placeholder');
                if(translations[currentLang][key]) el.setAttribute('placeholder', translations[currentLang][key]);
            });
        }

        // --- Progress Tracking Live Bar Simulation ---
        function processCheckout() {
            document.getElementById('checkoutBtn').disabled = true;
            const trackingPanel = document.getElementById('trackingPanel');
            trackingPanel.classList.add('active');
            trackingPanel.scrollIntoView({ behavior: 'smooth' });

            const progressLineFill = document.getElementById('progressLineFill');
            const steps = [document.getElementById('step1'), document.getElementById('step2'), document.getElementById('step3'), document.getElementById('step4')];
            const successBox = document.getElementById('successBox');
            const timerMsg = document.getElementById('timerMsg');

            steps.forEach(s => s.classList.remove('active', 'completed'));
            successBox.style.display = 'none';
            timerMsg.style.display = 'block';
            progressLineFill.style.width = '0%';

            setTimeout(() => { steps[0].classList.add('active'); progressLineFill.style.width = '12.5%'; }, 500);
            setTimeout(() => { steps[0].classList.replace('active', 'completed'); steps[1].classList.add('active'); progressLineFill.style.width = '37.5%'; }, 3000);
            setTimeout(() => { steps[1].classList.replace('active', 'completed'); steps[2].classList.add('active'); progressLineFill.style.width = '75%'; }, 6000);
            setTimeout(() => {
                steps[2].classList.replace('active', 'completed'); steps[3].classList.add('completed');
                progressLineFill.style.width = '100%';
                timerMsg.style.display = 'none';
                successBox.style.display = 'block';
                cart = [];
                renderCart();
            }, 9000);
        }
    </script>
</body>
</html>
