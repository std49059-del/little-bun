<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title data-i18n="app_title">School Food Ordering</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <style>
        /* --- CSS Reset & Variables --- */
        :root {
            --primary-yellow: #F2C94C;
            --soft-red: #D95D5D;
            --cream-bg: #FFF8E7;
            --dark-text: #333333;
            --white: #FFFFFF;
            --gray-light: #F0F0F0;
            --gray-dark: #828282;
            --shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            --transition: all 0.3s ease;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }
        body {
            font-family: 'Sarabun', 'Segoe UI', sans-serif;
            background-color: var(--cream-bg);
            color: var(--dark-text);
            line-height: 1.6;
        }

        /* --- Header & Sticky Navigation --- */
        header {
            background-color: var(--white);
            box-shadow: var(--shadow);
            position: sticky;
            top: 0;
            z-index: 1000;
        }
        .nav-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 20px;
        }
        .logo h1 { font-size: 1.5rem; color: var(--soft-red); font-weight: 700; }
        .nav-actions { display: flex; gap: 10px; align-items: center; }
        
        .btn-action {
            padding: 8px 16px;
            border-radius: 20px;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            border: none;
        }
        .lang-btn { background-color: var(--primary-yellow); color: var(--dark-text); }
        .lang-btn:hover { background-color: var(--soft-red); color: var(--white); }
        .login-toggle-btn { background-color: var(--dark-text); color: var(--white); }
        .logout-btn { background-color: #e74c3c; color: white; display: none; }

        /* --- Admin Info Bar --- */
        .admin-badge-bar {
            background-color: #27ae60;
            color: white;
            text-align: center;
            padding: 6px;
            font-size: 0.9rem;
            font-weight: bold;
            display: none;
        }

        /* --- Hero Section --- */
        .hero {
            background: linear-gradient(135deg, var(--primary-yellow) 0%, #fdedb9 100%);
            padding: 40px 20px;
            text-align: center;
            border-bottom-left-radius: 30px;
            border-bottom-right-radius: 30px;
            margin-bottom: 30px;
        }
        .hero h2 { font-size: 2rem; margin-bottom: 10px; }

        /* --- Grid Layout --- */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px 50px 20px;
            display: grid;
            grid-template-columns: 1fr;
            gap: 30px;
        }
        @media (min-width: 992px) { .container { grid-template-columns: 2fr 1fr; } }

        .card-panel {
            background-color: var(--white);
            padding: 25px;
            border-radius: 16px;
            box-shadow: var(--shadow);
            margin-bottom: 25px;
        }
        .section-title {
            font-size: 1.3rem;
            margin-bottom: 15px;
            border-left: 5px solid var(--soft-red);
            padding-left: 10px;
        }
        .form-group { margin-bottom: 15px; }
        label { display: block; margin-bottom: 5px; font-weight: 600; }
        select, textarea, input[type="text"], input[type="password"], input[type="email"], input[type="number"] {
            width: 100%;
            padding: 12px;
            border: 1px solid var(--gray-light);
            border-radius: 8px;
            font-family: inherit;
            font-size: 1rem;
            background-color: #fafafa;
        }

        /* --- Responsive Shops Grid --- */
        .shops-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
        @media (max-width: 1199px) { .shops-grid { grid-template-columns: repeat(3, 1fr); } }
        @media (max-width: 768px) { .shops-grid { grid-template-columns: repeat(2, 1fr); } }
        @media (max-width: 480px) { .shops-grid { grid-template-columns: 1fr; } }

        .shop-card {
            background-color: var(--white);
            border-radius: 12px;
            overflow: hidden;
            box-shadow: var(--shadow);
            transition: var(--transition);
            display: flex;
            flex-direction: column;
        }
        .shop-card:hover { transform: translateY(-5px); box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1); }
        .shop-img { width: 100%; height: 140px; object-fit: cover; }
        .shop-info { padding: 15px; flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between; }
        .shop-name { font-size: 1rem; font-weight: 600; margin-bottom: 15px; height: 48px; }

        .btn {
            background-color: var(--soft-red);
            color: var(--white);
            border: none;
            padding: 10px 15px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            width: 100%;
            transition: var(--transition);
            text-align: center;
        }
        .btn:hover { filter: brightness(0.9); }
        .btn-yellow { background-color: var(--primary-yellow); color: var(--dark-text); }
        .btn-yellow:disabled { background-color: var(--gray-light); color: var(--gray-dark); cursor: not-allowed; }

        /* --- Modal Styles --- */
        .modal {
            display: none;
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background-color: rgba(0,0,0,0.5); z-index: 2000;
            justify-content: center; align-items: center; padding: 20px;
            backdrop-filter: blur(3px);
        }
        .modal.active { display: flex; }
        .modal-content {
            background-color: var(--white); border-radius: 16px;
            width: 100%; max-width: 600px; max-height: 85vh; overflow-y: auto;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2); animation: modalFade 0.3s ease;
        }
        @keyframes modalFade { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        .modal-header { padding: 20px; border-bottom: 1px solid var(--gray-light); display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; background: white; }
        .close-modal { font-size: 1.5rem; cursor: pointer; background: none; border: none; }
        .modal-body { padding: 20px; }

        /* --- Menu Items & Admin Edit Form --- */
        .menu-item { padding: 15px 0; border-bottom: 1px solid var(--gray-light); }
        .menu-item.out-of-stock { opacity: 0.6; }
        .menu-details { display: flex; justify-content: space-between; margin-bottom: 10px; }
        .menu-price { color: var(--soft-red); font-weight: 600; }
        .badge { padding: 2px 6px; font-size: 0.75rem; border-radius: 4px; font-weight: bold; }
        .badge.bg-red { background-color: #ffeaea; color: var(--soft-red); }
        .badge.bg-green { background-color: #e6f9ed; color: #27ae60; }
        
        .custom-box { background-color: #fdfaf2; padding: 12px; border-radius: 8px; font-size: 0.9rem; }
        .custom-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; margin: 8px 0; }
        
        /* แผงแก้ไขสำหรับแอดมิน */
        .admin-edit-panel {
            background-color: #edf2f7;
            padding: 12px;
            border-radius: 8px;
            margin-top: 10px;
            border: 1px dashed #cbd5e0;
        }

        /* --- Cart & Tracking --- */
        .cart-panel { position: sticky; top: 90px; }
        .cart-item { display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--gray-light); font-size: 0.95rem; }
        .cart-item-shop { font-size: 0.75rem; color: var(--gray-dark); display: block; }
        .cart-item-customs { font-size: 0.8rem; color: #7f8c8d; display: block; }
        .delete-btn { background: none; border: none; color: var(--soft-red); cursor: pointer; text-decoration: underline; font-size: 0.85rem; }
        .total-price { display: flex; justify-content: space-between; font-size: 1.2rem; font-weight: 700; margin: 20px 0; padding-top: 10px; border-top: 2px dashed var(--gray-light); }
        
        .tracking-panel { display: none; background-color: var(--white); padding: 25px; border-radius: 16px; margin-top: 25px; border: 2px solid var(--primary-yellow); }
        .tracking-panel.active { display: block; }
        .timer-msg { font-size: 1.1rem; font-weight: 600; color: var(--soft-red); text-align: center; margin-bottom: 20px; }
        
        /* Progress Bar */
        .progress-container { display: flex; justify-content: space-between; position: relative; margin-bottom: 20px; }
        .progress-line { position: absolute; top: 15px; left: 0; height: 4px; background-color: var(--gray-light); width: 100%; z-index: 1; }
        .progress-line-fill { position: absolute; top: 15px; left: 0; height: 4px; background-color: var(--primary-yellow); width: 0%; z-index: 2; transition: width 1s linear; }
        .step { position: relative; z-index: 3; display: flex; flex-direction: column; align-items: center; font-size: 0.8rem; font-weight: 600; color: var(--gray-dark); width: 25%; }
        .step-dot { width: 34px; height: 34px; border-radius: 50%; background-color: var(--white); border: 3px solid var(--gray-light); display: flex; justify-content: center; align-items: center; margin-bottom: 8px; }
        .step.active .step-dot { border-color: var(--primary-yellow); background-color: var(--primary-yellow); }
        .step.completed .step-dot { border-color: var(--soft-red); background-color: var(--soft-red); color: white; }
        .success-box { display: none; background-color: #e6f9ed; color: #27ae60; padding: 20px; border-radius: 12px; text-align: center; font-weight: bold; font-size: 1.2rem; }
        .error-msg { color: var(--soft-red); font-size: 0.9rem; margin-top: 5px; display: none; text-align: center;}
    </style>
</head>
