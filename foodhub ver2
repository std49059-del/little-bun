    </section>

    <div id="mainApp">
        <main class="container">
            <div class="main-content">
                <section class="card-panel">
                    <h3 class="section-title" data-i18n="location_title">ระบุสถานที่จัดส่ง</h3>
                    <div class="form-group">
                        <label for="buildingSelect" data-i18n="label_building">เลือกอาคาร/สถานที่</label>
                        <select id="buildingSelect"></select>
                    </div>
                    <div class="form-group">
                        <label for="locationDetails" data-i18n="label_details">ข้อมูลเพิ่มเติม (ระบุจุดนัดรับ)</label>
                        <textarea id="locationDetails" rows="2" data-i18n-placeholder="placeholder_details" placeholder="เช่น อยู่หน้าห้อง 302..."></textarea>
                    </div>
                </section>

                <section class="card-panel">
                    <h3 class="section-title" data-i18n="shops_title">ร้านค้าทั้งหมด (14 ร้าน)</h3>
                    <div class="shops-grid" id="shopsGrid"></div>
                </section>
            </div>

            <div class="side-content">
                <section class="card-panel cart-panel">
                    <h3 class="section-title" data-i18n="cart_title">ตะกร้าสินค้าของคุณ</h3>
                    <div id="cartItemsContainer">
                        <p style="text-align: center; color: var(--gray-dark); padding: 20px 0;" data-i18n="cart_empty">ไม่มีสินค้าในตะกร้า</p>
                    </div>
                    
                    <div class="total-price">
                        <span data-i18n="cart_total">ราคารวม:</span>
                        <span>฿<span id="cartTotalAmount">0</span></span>
                    </div>

                    <button class="btn btn-yellow" id="checkoutBtn" onclick="processCheckout()" disabled data-i18n="btn_checkout">สั่งซื้ออาหาร</button>
                    
                    <div class="tracking-panel" id="trackingPanel">
                        <h3 class="section-title" data-i18n="track_title">ติดตามออเดอร์</h3>
                        <p class="timer-msg" id="timerMsg" data-i18n="track_timer">อีก 15 นาทีอาหารจะถึงมือคุณ</p>
                        
                        <div class="progress-container">
                            <div class="progress-line"></div>
                            <div class="progress-line-fill" id="progressLineFill"></div>
                            <div class="step" id="step1"><div class="step-dot">1</div><span data-i18n="step_prep">Preparing</span></div>
                            <div class="step" id="step2"><div class="step-dot">2</div><span data-i18n="step_cook">Cooking</span></div>
                            <div class="step" id="step3"><div class="step-dot">3</div><span data-i18n="step_deliv">Delivering</span></div>
                            <div class="step" id="step4"><div class="step-dot">4</div><span data-i18n="step_comp">Completed</span></div>
                        </div>
                        <div class="success-box" id="successBox" data-i18n="delivery_completed">การส่งเสร็จสิ้นแล้ว</div>
                    </div>
                </section>
            </div>
        </main>
    </div>

    <div class="modal" id="loginModal">
        <div class="modal-content" style="max-width: 400px;">
            <div class="modal-header">
                <h3 data-i18n="login_title">เข้าสู่ระบบควบคุมร้านค้า</h3>
                <button class="close-modal" onclick="closeLoginModal()">&times;</button>
            </div>
            <div class="modal-body">
                <form id="loginForm" onsubmit="handleLogin(event)">
                    <div class="form-group">
                        <label data-i18n="login_email">อีเมลควบคุม</label>
                        <input type="email" id="loginEmail" required placeholder="std49059@sriyapai.ac.th">
                    </div>
                    <div class="form-group">
                        <label data-i18n="login_password">รหัสผ่าน</label>
